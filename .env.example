# Purser configuration (copy to .env; .env is gitignored).
# 12-factor env vars, PURSER_-prefixed, DATABASE_URL fallback — house style.

# --- Core ---
PURSER_ADDR=:4006
# Shared construct-server Postgres 16 (purser DB + role — see construct-server db/init-db.sh).
PURSER_DATABASE_URL=postgres://purser_user:CHANGE_ME@postgres:5432/purser?sslmode=disable
# Bearer token protecting the HTTP API. Leave empty ONLY if you rely on
# construct_net/Tailscale isolation (a startup warning is logged).
PURSER_API_TOKEN=

# --- Switchyard connector ---
# Internal API base on construct_net (not the public tunnel host).
PURSER_SWITCHYARD_BASE_URL=http://switchyard:4002
# Admin-capable Switchyard token (sw_…) owned by an owner-human or agent user,
# scoped `admin` (typically the instance BOOTSTRAP_TOKEN). Required to provision.
PURSER_SWITCHYARD_TOKEN=
# Public login URL shown in the credential block.
PURSER_SWITCHYARD_URL=https://switchyard.zerogravity.industries

# --- Cloudflare Access connector (adds people to SSO) ---
# When these are unset, `--to cloudflare` prints the manual dashboard step
# instead of granting access via the API.
# API token scoped: Account > Access: Organizations, Identity Providers, and Groups: Edit.
PURSER_CF_API_TOKEN=
PURSER_CF_ACCOUNT_ID=
# The shared Access group every app policy allows (recommended model — one grant
# covers all tunneled apps). Create it in the Zero Trust dashboard, then set its id.
PURSER_CF_ACCESS_GROUP_ID=
PURSER_CF_ACCESS_GROUP_NAME=zerogravity-members
PURSER_CF_TEAM_DOMAIN=zero-gravity-industries.cloudflareaccess.com
PURSER_CF_APPS_NOTE=Switchyard and the other tunneled Construct apps

# --- Lyceum connector (ebook reader; SERV-38) ---
# Unset => `--to lyceum` is registered but Unavailable. Requires the lyceum
# service to run with LYCEUM_AUTH=true, and an owner *session* token here
# (obtain once: `lyceum mint-token` on the host → redeem via POST /auth/session;
# the resulting session token never expires). Not a LYCEUM_API_TOKENS entry.
PURSER_LYCEUM_BASE_URL=http://lyceum:4005
PURSER_LYCEUM_OWNER_TOKEN=
# Public app URL for the credential block's redemption note (optional; Lyceum
# isn't tunnelled yet).
PURSER_LYCEUM_URL=

# --- Email delivery (optional; enables --deliver email) ---
PURSER_SMTP_HOST=
PURSER_SMTP_PORT=587
PURSER_SMTP_USERNAME=
PURSER_SMTP_PASSWORD=
PURSER_SMTP_FROM=purser@zerogravity.industries
PURSER_SMTP_TLS=starttls
